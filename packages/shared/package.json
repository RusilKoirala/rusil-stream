{
  "name": "@streaming-app/shared",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --config=packages/shared/jest.config.js"
  },
  "dependencies": {
    "expo-secure-store": "*"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".js"
    ],
    "transform": {},
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^expo-secure-store$": "<rootDir>/src/auth/__mocks__/expo-secure-store.js"
    }
  }
}
