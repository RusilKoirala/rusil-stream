{
  "name": "my-nextjs-movie-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "clean:next": "node scripts/clean-next-cache.js",
    "dev:clean": "npm run clean:next && next dev",
    "build": "npm run build --workspace=apps/web",
    "build:apks": "./scripts/build-apks.sh",
    "build:mobile": "./scripts/build-apks.sh --mobile-only",
    "build:tv": "./scripts/build-apks.sh --tv-only",
    "start": "npm run start --workspace=apps/web",
    "lint": "next lint",
    "seed": "node scripts/seed.js",
    "fix-indexes": "node scripts/fix-indexes.js",
    "reset-verification": "node scripts/reset-verification.js",
    "vercel-build": "npm run build --workspace=apps/web"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@vercel/analytics": "^1.6.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "hls.js": "^1.6.15",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "mongoose": "^9.0.1",
    "next": "15.3.6",
    "node-fetch": "^3.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.5.2",
    "swr": "^2.3.7",
    "tailwindcss": "^4"
  },
  "workspaces": ["apps/*", "packages/*"],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "framer-motion": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "shadcn": "^4.1.0"
  },
  "eslintConfig": {
    "extends": "next/core-web-vitals"
  }
}
